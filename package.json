{
  "name": "noteria-cloudflare",
  "version": "1.0.0",
  "description": "E-Noteria CloudFlare Deployment",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --local",
    "deploy": "wrangler publish",
    "deploy:prod": "wrangler publish --env production",
    "build": "esbuild src/index.js --bundle --minify --platform=browser --outfile=dist/index.js",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "lint": "eslint src/"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "itty-router": "^4.2.2",
    "multer": "^2.1.1",
    "mysql2": "^3.20.0"
  },
  "devDependencies": {
    "@cloudflare/types": "^6.10.0",
    "esbuild": "^0.27.4",
    "jest": "^29.7.0",
    "typescript": "^5.3.0",
    "wrangler": "^4.77.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
